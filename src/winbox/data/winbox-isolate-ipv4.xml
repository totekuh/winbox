<filter name='winbox-isolate-ipv4' chain='ipv4'>
  <!-- DHCPv4 client: allow renewals so Windows doesn't mark the NIC
       "unidentified" or strip the IP. -->
  <rule action='accept' direction='out' priority='100'>
    <udp srcportstart='68' dstportstart='67'/>
  </rule>
  <rule action='accept' direction='in' priority='100'>
    <udp srcportstart='67' dstportstart='68'/>
  </rule>

  <!-- Intra-subnet (rendered from cfg.vm_subnet / cfg.vm_subnet_mask). -->
  <rule action='accept' direction='inout' priority='200'>
    <ip srcipaddr='{subnet}' srcipmask='{mask}'
        dstipaddr='{subnet}' dstipmask='{mask}'/>
  </rule>

  <!-- Default drop for IPv4. -->
  <rule action='drop' direction='inout' priority='1000'/>
</filter>
