<?xml version="1.0" encoding="utf-8"?>
<unattend xmlns="urn:schemas-microsoft-com:unattend">

  <!-- Windows PE: disk config + install image -->
  <settings pass="windowsPE">
    <component name="Microsoft-Windows-International-Core-WinPE"
               processorArchitecture="amd64" publicKeyToken="31bf3856ad364e35"
               language="neutral" versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">
      <SetupUILanguage>
        <UILanguage>en-US</UILanguage>
      </SetupUILanguage>
      <InputLocale>en-US</InputLocale>
      <SystemLocale>en-US</SystemLocale>
      <UILanguage>en-US</UILanguage>
      <UserLocale>en-US</UserLocale>
    </component>

    <component name="Microsoft-Windows-Setup"
               processorArchitecture="amd64" publicKeyToken="31bf3856ad364e35"
               language="neutral" versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">

      <!-- Use evaluation key for Server Standard Core -->
      <UserData>
        <ProductKey>
          <Key>VDYBN-27WPP-V4HQT-9VMD4-VMK7H</Key>
          <WillShowUI>Never</WillShowUI>
        </ProductKey>
        <AcceptEula>true</AcceptEula>
      </UserData>

      <ImageInstall>
        <OSImage>
          <InstallFrom>
            <MetaData wcm:action="add">
              <Key>/IMAGE/NAME</Key>
              <Value>Windows Server 2022 SERVERSTANDARDCORE</Value>
            </MetaData>
          </InstallFrom>
          <InstallTo>
            <DiskID>0</DiskID>
            <PartitionID>2</PartitionID>
          </InstallTo>
        </OSImage>
      </ImageInstall>

      <DiskConfiguration>
        <Disk wcm:action="add">
          <DiskID>0</DiskID>
          <WillWipeDisk>true</WillWipeDisk>
          <CreatePartitions>
            <!-- EFI System Partition -->
            <CreatePartition wcm:action="add">
              <Order>1</Order>
              <Size>100</Size>
              <Type>EFI</Type>
            </CreatePartition>
            <!-- Windows partition (rest of disk) -->
            <CreatePartition wcm:action="add">
              <Order>2</Order>
              <Extend>true</Extend>
              <Type>Primary</Type>
            </CreatePartition>
          </CreatePartitions>
          <ModifyPartitions>
            <ModifyPartition wcm:action="add">
              <Order>1</Order>
              <PartitionID>1</PartitionID>
              <Format>FAT32</Format>
              <Label>EFI</Label>
            </ModifyPartition>
            <ModifyPartition wcm:action="add">
              <Order>2</Order>
              <PartitionID>2</PartitionID>
              <Format>NTFS</Format>
              <Label>Windows</Label>
            </ModifyPartition>
          </ModifyPartitions>
        </Disk>
      </DiskConfiguration>

      <!-- Load VirtIO storage driver from CD -->
      <DriverPaths>
        <PathAndCredentials wcm:action="add" wcm:keyValue="1">
          <Path>E:\viostor\w11\amd64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="2">
          <Path>E:\NetKVM\w11\amd64</Path>
        </PathAndCredentials>
      </DriverPaths>

    </component>
  </settings>

  <!-- Specialize: computer name, drivers -->
  <settings pass="specialize">
    <component name="Microsoft-Windows-Shell-Setup"
               processorArchitecture="amd64" publicKeyToken="31bf3856ad364e35"
               language="neutral" versionScope="nonSxS">
      <ComputerName>WINBOX</ComputerName>
      <TimeZone>UTC</TimeZone>
    </component>
  </settings>

  <!-- OOBE: admin account, auto-logon, first-run commands -->
  <settings pass="oobeSystem">
    <component name="Microsoft-Windows-Shell-Setup"
               processorArchitecture="amd64" publicKeyToken="31bf3856ad364e35"
               language="neutral" versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">

      <OOBE>
        <HideEULAPage>true</HideEULAPage>
        <HideLocalAccountScreen>true</HideLocalAccountScreen>
        <HideOEMRegistrationScreen>true</HideOEMRegistrationScreen>
        <HideOnlineAccountScreens>true</HideOnlineAccountScreens>
        <HideWirelessSetupInOOBE>true</HideWirelessSetupInOOBE>
        <ProtectYourPC>3</ProtectYourPC>
        <NetworkLocation>Work</NetworkLocation>
      </OOBE>

      <UserAccounts>
        <AdministratorPassword>
          <Value>V2luYm94UEBzczEyMw==</Value>
          <PlainText>false</PlainText>
        </AdministratorPassword>
        <LocalAccounts>
          <LocalAccount wcm:action="add">
            <Name>winbox</Name>
            <Group>Administrators</Group>
            <Password>
              <Value>V2luYm94UEBzczEyMw==</Value>
              <PlainText>false</PlainText>
            </Password>
          </LocalAccount>
        </LocalAccounts>
      </UserAccounts>

      <AutoLogon>
        <Enabled>true</Enabled>
        <Username>winbox</Username>
        <Password>
          <Value>V2luYm94UEBzczEyMw==</Value>
          <PlainText>false</PlainText>
        </Password>
        <LogonCount>3</LogonCount>
      </AutoLogon>

      <FirstLogonCommands>
        <!-- Install QEMU Guest Agent from VirtIO CD -->
        <SynchronousCommand wcm:action="add">
          <Order>1</Order>
          <CommandLine>msiexec /i E:\guest-agent\qemu-ga-x86_64.msi /qn</CommandLine>
          <Description>Install QEMU Guest Agent</Description>
        </SynchronousCommand>

        <!-- Install VirtIO FS driver -->
        <SynchronousCommand wcm:action="add">
          <Order>2</Order>
          <CommandLine>cmd /c pnputil /add-driver E:\viofs\w11\amd64\viofs.inf /install</CommandLine>
          <Description>Install VirtIO FS driver</Description>
        </SynchronousCommand>

        <!-- Start VirtIO FS service to mount shared folder as Z: -->
        <SynchronousCommand wcm:action="add">
          <Order>3</Order>
          <CommandLine>cmd /c sc create VirtioFsSvc binPath="C:\Program Files\Virtio-Win\VioFS\virtiofs.exe" start=auto depend=VirtioFsDrv</CommandLine>
          <Description>Create VirtioFS service</Description>
        </SynchronousCommand>
        <SynchronousCommand wcm:action="add">
          <Order>4</Order>
          <CommandLine>cmd /c net start VirtioFsSvc</CommandLine>
          <Description>Start VirtioFS service</Description>
        </SynchronousCommand>

        <!-- Map virtiofs share to Z: drive -->
        <SynchronousCommand wcm:action="add">
          <Order>5</Order>
          <CommandLine>cmd /c "net use Z: \\?\UNC\winbox_share\ /persistent:yes || subst Z: C:\winbox_share"</CommandLine>
          <Description>Map shared folder to Z:</Description>
        </SynchronousCommand>

        <!-- Disable Windows Defender -->
        <SynchronousCommand wcm:action="add">
          <Order>6</Order>
          <CommandLine>powershell -Command "Set-MpPreference -DisableRealtimeMonitoring $true; Set-MpPreference -DisableIOAVProtection $true"</CommandLine>
          <Description>Disable Windows Defender</Description>
        </SynchronousCommand>

        <!-- Disable Firewall -->
        <SynchronousCommand wcm:action="add">
          <Order>7</Order>
          <CommandLine>powershell -Command "Set-NetFirewallProfile -Profile Domain,Public,Private -Enabled False"</CommandLine>
          <Description>Disable Firewall</Description>
        </SynchronousCommand>

        <!-- Install .NET Framework 4.7.2 (usually already present on Server 2022) -->
        <SynchronousCommand wcm:action="add">
          <Order>8</Order>
          <CommandLine>powershell -Command "Install-WindowsFeature Net-Framework-45-Core -ErrorAction SilentlyContinue"</CommandLine>
          <Description>Ensure .NET Framework</Description>
        </SynchronousCommand>
      </FirstLogonCommands>

    </component>
  </settings>

</unattend>
